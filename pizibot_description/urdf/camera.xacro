<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <joint name="camera_joint" type="fixed">
        <parent link="chassis"/>
        <child link="camera_link"/>
        <origin xyz="0 ${camera_x_offset} ${camera_z_offset}" rpy="0 0 ${pi/2}"/>
    </joint>

    <link name="camera_link">
    </link>

    <joint name="camera_optical_joint" type="fixed">
        <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}" />
        <parent link="camera_link" />
        <child link="camera_link_optical" />
    </joint>

    <link name="camera_link_optical"></link>

    <gazebo reference="camera_link">
        <material>Gazebo/Red</material>
        <sensor name="camera" type="camera">
            <pose>0 0 0 0 0 0</pose>
            <visualize>true</visualize>
            <update_rate>${camera_update_rate}</update_rate>
            <camera>
                <horizontal_fov>${camera_horizontal_fov}</horizontal_fov>
                <image>
                    <format>R8G8B8</format>
                    <width>${camera_image_width}</width>
                    <height>${camera_image_height}</height>
                </image>
                <clip>
                    <near>${camera_clip_near}</near>
                    <far>${camera_clip_far}</far>
                </clip>
            </camera>
            <topic>camera/image_raw</topic>
            <camera_info_topic>camera/camera_info</camera_info_topic>
            <gz_frame_id>camera_link_optical</gz_frame_id>
        </sensor>
    </gazebo>

    <!-- Semantic Segmentation Camera Sensor for Gazebo Harmonic -->
    <!-- Provides pixel-wise semantic labels for scene understanding in simulation -->
    <!-- Publishes to /camera/semantic/labels_map and /camera/semantic/colored_map topics -->
    <gazebo reference="camera_link">
        <sensor name="segmentation_camera" type="segmentation">
            <pose>0 0 0 0 0 0</pose>
            <visualize>true</visualize>
            <update_rate>${camera_update_rate}</update_rate>
            <camera>
                <horizontal_fov>${camera_horizontal_fov}</horizontal_fov>
                <image>
                    <width>${camera_image_width}</width>
                    <height>${camera_image_height}</height>
                </image>
                <clip>
                    <near>${camera_clip_near}</near>
                    <far>${camera_clip_far}</far>
                </clip>
            </camera>
            <always_on>1</always_on>
            <topic>camera/semantic</topic>
            <gz_frame_id>camera_link_optical</gz_frame_id>
        </sensor>
    </gazebo>

</robot>
